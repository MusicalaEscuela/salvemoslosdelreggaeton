rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function email() {
      return request.auth.token.email;
    }

    function isInitialEditor() {
      return isSignedIn() && email() in [
        "alekcaballeromusic@gmail.com",
        "catalina.medina.leal@gmail.com"
      ];
    }

    function hasEditorRole() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/roles/$(email()))
        && get(/databases/$(database)/documents/roles/$(email())).data.canEdit == true;
    }

    function isEditor() {
      return isInitialEditor() || hasEditorRole();
    }

    match /songs/{songId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isEditor();

      match /requirements/{requirementId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isEditor();
      }

      match /assignments/{assignmentId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isEditor();
      }
    }

    match /bands/{bandId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isEditor();
    }

    match /musicians/{musicianId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isEditor();
    }

    match /roles/{roleEmail} {
      allow read: if isEditor() || (isSignedIn() && email() == roleEmail);
      allow create, update, delete: if isEditor();
    }
  }
}
